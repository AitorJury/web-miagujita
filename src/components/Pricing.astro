---
const pantalones = [
  { item: "Bajos a mano", price: "8€" },
  { item: "Bajos a máquina", price: "5€" },
  { item: "Bajos con vuelta", price: "10€" },
  { item: "Cambiar cremallera", price: "10€", note: "+ cremallera" },
  { item: "Estrechar / Ensanchar cintura", price: "10€ - 15€" },
];

const camisas = [
  { item: "Bajos", price: "7€" },
  { item: "Entallar / Ensanchar", price: "10€" },
  { item: "Acortar mangas con puño", price: "8€" },
  { item: "Quitar mangas", price: "12€" },
  { item: "Coser botón", price: "1,5€", note: "+ botón" },
];
---

<section id="tarifas" class="max-w-5xl mx-auto px-6 py-20">
  <div class="text-center mb-16 space-y-4">
    <h2 class="font-serif text-4xl lg:text-5xl text-agujita-text">
      Lista de <span class="text-agujita-primary italic">Precios</span>
    </h2>
    <p class="font-sans text-agujita-text/70 text-lg">
      Tarifas base para composturas y arreglos
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
    <div class="space-y-6">
      <h3
        class="font-serif text-2xl text-agujita-primary border-b border-agujita-primary/20 pb-4 uppercase tracking-wider text-center md:text-left"
      >
        Arreglo de Pantalones
      </h3>
      <ul class="space-y-4">
        {
          pantalones.map((line) => (
            <li class="flex items-baseline justify-between font-sans">
              <span class="text-agujita-text/80">{line.item}</span>
              <div class="flex-grow border-b border-dotted border-agujita-text/20 mx-4" />
              <span class="text-agujita-text font-medium text-right">
                {line.price}
                {line.note && (
                  <span class="text-xs text-agujita-text/50 block font-normal">
                    {line.note}
                  </span>
                )}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="space-y-6">
      <h3
        class="font-serif text-2xl text-agujita-primary border-b border-agujita-primary/20 pb-4 uppercase tracking-wider text-center md:text-left"
      >
        Camisas y Blusas
      </h3>
      <ul class="space-y-4">
        {
          camisas.map((line) => (
            <li class="flex items-baseline justify-between font-sans">
              <span class="text-agujita-text/80">{line.item}</span>
              <div class="flex-grow border-b border-dotted border-agujita-text/20 mx-4" />
              <span class="text-agujita-text font-medium text-right">
                {line.price}
                {line.note && (
                  <span class="text-xs text-agujita-text/50 block font-normal">
                    {line.note}
                  </span>
                )}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="mt-12 text-center text-sm text-agujita-text/60 italic font-sans">
    * Consulta para más arreglos (faldas, chaquetas, sudaderas y hogar). Los
    precios pueden variar según la complejidad.
  </div>
</section>
