---
import { products } from "../data/products.js";
import { Image } from "astro:assets";
---

<section id="galeria" class="max-w-7xl mx-auto px-6 py-20">
  <div class="text-center mb-12 space-y-4">
    <h2 class="font-serif text-4xl lg:text-5xl text-agujita-text">
      Algunos de mis <span class="text-agujita-primary italic">trabajos</span>
    </h2>
    <p class="font-sans text-agujita-text/70 text-lg">
      Inspiración directa desde el taller
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    {
      products.map((item) => (
        <a
          href={`/producto/${item.id}`}
          class={`group relative rounded-2xl overflow-hidden shadow-sm border border-agujita-primary/10 block ${item.class}`}
        >
          <Image
            src={item.image}
            alt={item.title}
            transition:name={`img-${item.id}`}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />

          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-agujita-text/90 via-agujita-text/40 to-transparent p-5 flex flex-col justify-end h-1/2">
            <h3 class="font-serif text-xl md:text-2xl text-white font-medium drop-shadow-md">
              {item.title}
            </h3>
            <span class="text-xs font-bold text-white/90 uppercase tracking-widest mt-2 flex items-center gap-1 group-hover:text-agujita-primary transition-colors duration-300">
              Ver detalles <span class="text-lg leading-none">→</span>
            </span>
          </div>
        </a>
      ))
    }
  </div>
</section>
