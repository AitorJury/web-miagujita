---
import { products } from "../data/products.js";
---

<section id="galeria" class="max-w-7xl mx-auto px-6 py-20">
  <div class="text-center mb-12 space-y-4">
    <h2 class="font-serif text-4xl lg:text-5xl text-agujita-text">
      Algunos de mis <span class="text-agujita-primary italic">trabajos</span>
    </h2>
    <p class="font-sans text-agujita-text/70 text-lg">
      Inspiración directa desde el taller
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    {
      products.map((item) => (
        <a
          href={`/producto/${item.id}`}
          class={`group relative rounded-2xl overflow-hidden cursor-pointer shadow-sm border border-agujita-primary/10 block ${item.class}`}
        >
          <img
            src={item.image}
            alt={item.title}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
          />

          <div class="absolute inset-0 bg-agujita-text/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center p-4">
            <span class="font-serif text-2xl text-white font-medium text-center">
              {item.title}
            </span>
          </div>
        </a>
      ))
    }
  </div>
</section>
