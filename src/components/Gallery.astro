---
const items = [
  { id: 1, title: "Neceser personalizado", class: "aspect-square" },
  { id: 2, title: "Arreglo de vestido", class: "aspect-[4/3] md:col-span-2" },
  { id: 3, title: "Bolsa de tela (Tote bag)", class: "aspect-square" },
  { id: 4, title: "Cortinas a medida", class: "aspect-square md:col-span-2" },
  { id: 5, title: "Bordado a mano", class: "aspect-[4/3]" },
];
---

<section id="galeria" class="max-w-7xl mx-auto px-6 py-20">
  <div class="text-center mb-12 space-y-4">
    <h2 class="font-serif text-4xl lg:text-5xl text-agujita-text">
      Algunos de mis <span class="text-agujita-primary italic">trabajos</span>
    </h2>
    <p class="font-sans text-agujita-text/70 text-lg">Inspiración directa desde el taller</p>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    {items.map(item => (
      <div class={`bg-agujita-primary/5 rounded-2xl flex items-center justify-center p-6 text-center border border-agujita-primary/10 hover:bg-agujita-primary/10 hover:scale-[1.02] transition-all duration-300 cursor-pointer shadow-sm ${item.class}`}>
        <span class="font-sans text-sm text-agujita-text/60 font-medium">
          {item.title} <br/> 
          <span class="text-xs opacity-50">(Espacio para foto)</span>
        </span>
      </div>
    ))}
  </div>
</section>