---
/**
 * @file Layout.astro
 * @description Layout global (App Shell) que envuelve todas las páginas de la aplicación.
 * * Arquitectura y Rendimiento:
 * - Patrón de Composición: Usa el elemento <slot /> nativo de Astro para inyectar
 * el contenido hijo, manteniendo la estructura HTML base y los metadatos centralizados.
 * - SPA Feeling (ClientRouter): Implementa la API de View Transitions de Astro 5.
 * Intercepta la navegación para hacer un "diffing" (comparación) del DOM y animar
 * los cambios, logrando que una web estática (MPA) rinda y se sienta como una
 * Single Page Application (SPA).
 * - SEO & Open Graph: Configuración base para indexación correcta en Google y
 * previsualizaciones enriquecidas (tarjetas con foto) al compartir en WhatsApp o redes sociales.
 */

import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta
      name="description"
      content="Costura creativa & piezas con alma. Tu estilo, mi aguja. Hecho a mano en Barcelona."
    />

    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Mi Agujita | Costura Creativa" />
    <meta
      property="og:description"
      content="Piezas únicas, arreglos y textiles del hogar con alma. Barcelona."
    />
    <meta property="og:image" content="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />
  </head>

  <body class="min-h-screen flex flex-col">
    <main class="grow">
      <slot />
    </main>

    <Analytics />
  </body>
</html>
